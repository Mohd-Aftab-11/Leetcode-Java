class Solution {
    private static final int MOD = 1000000007;
    
    public int sumOfNumbers(int l, int r, int k) {
        long n = r - l + 1;

        long digitSum = ((long)(l + r)* n / 2) % MOD;

        long nPowKMinus1;
        if (k == 1) {
            nPowKMinus1 = 1;
        } else {
            nPowKMinus1 = fastPow(n, k - 1);
        }

        long tenPowK = fastPow(10, k);

        long inverse9 = modInverse(9);

        long geometricSum = ((tenPowK - 1 + MOD) % MOD * inverse9) % MOD;

        long result = (digitSum * nPowKMinus1) % MOD; 
        result = (result * geometricSum) % MOD;

        return (int) result;
    }
        private long fastPow(long base, long exp) {
            if (exp == 0) return 1;
            
            long result = 1;
            base %= MOD;

            while (exp > 0){
                if ((exp & 1) == 1) {
                    result = (result * base) % MOD;
                }
                base = (base * base) % MOD;
                exp >>= 1;
            }
            return result;
        }
        private long modInverse(long a) {
            return fastPow(a, MOD - 2);
    }
}
