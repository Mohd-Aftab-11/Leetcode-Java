class Solution {
    public int minSwaps(int[][] grid) {
        int n = grid.length;
        int[] trailingZeros = new int[n];
        
        for (int i = 0; i < n; i++) {
            int zeros = 0;
            for (int j = n - 1; j >= 0; j--) {
                if (grid[i][j] == 0) {
                    zeros++;
                } else {
                    break;
                }
            }
            trailingZeros[i] = zeros;
        }
        
        int swaps = 0;
        
        for (int i = 0; i < n; i++) {
            int needed = n - i - 1;
            int found = -1;
            for (int j = i; j < n; j++) {
                if (trailingZeros[j] >= needed) {
                    found = j;
                    break;
                }
            }
            
            if (found == -1) {
                return -1;
            }
            
            for (int j = found; j > i; j--) {
                int temp = trailingZeros[j];
                trailingZeros[j] = trailingZeros[j-1];
                trailingZeros[j-1] = temp;
                swaps++;
            }
        }
        
        return swaps;
    }
}
