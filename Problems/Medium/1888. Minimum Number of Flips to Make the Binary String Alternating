class Solution {
    public int minFlips(String s) {
        int n = s.length();
        String doubled = s + s;
        
        StringBuilder target1 = new StringBuilder();
        StringBuilder target2 = new StringBuilder();
        
        for (int i = 0; i < 2 * n; i++) {
            target1.append(i % 2 == 0 ? '0' : '1');
            target2.append(i % 2 == 0 ? '1' : '0');
        }
        
        int minFlips = n;
        
        int diff1 = 0, diff2 = 0;
        
        for (int i = 0; i < n; i++) {
            if (doubled.charAt(i) != target1.charAt(i)) diff1++;
            if (doubled.charAt(i) != target2.charAt(i)) diff2++;
        }
        
        minFlips = Math.min(minFlips, Math.min(diff1, diff2));
        
        for (int i = 1; i < n; i++) {
            if (doubled.charAt(i - 1) != target1.charAt(i - 1)) diff1--;
            if (doubled.charAt(i - 1) != target2.charAt(i - 1)) diff2--;
            
            if (doubled.charAt(i + n - 1) != target1.charAt(i + n - 1)) diff1++;
            if (doubled.charAt(i + n - 1) != target2.charAt(i + n - 1)) diff2++;
            
            minFlips = Math.min(minFlips, Math.min(diff1, diff2));
        }
        
        return minFlips;
    }
}
