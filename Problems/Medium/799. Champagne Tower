class Solution {
    public double champagneTower(int poured, int query_row, int query_glass) {
        double[][] tower = new double[query_row + 2][query_row + 2];
        
        tower[0][0] = poured;
        
        for (int row = 0; row <= query_row; row++) {
            for (int col = 0; col <= row; col++) {
                if (tower[row][col] > 1) {
                    double excess = tower[row][col] - 1;
                    tower[row + 1][col] += excess / 2.0;
                    tower[row + 1][col + 1] += excess / 2.0;
                    tower[row][col] = 1;
                }
            }
        }
        
        return Math.min(tower[query_row][query_glass], 1.0);
    }
}
