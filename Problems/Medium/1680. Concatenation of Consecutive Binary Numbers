class Solution {
    public int concatenatedBinary(int n) {
        final int MOD = 1000000007;
        long result = 0;
        
        for (int i = 1; i <= n; i++) {
            int bitLength = (int)(Math.log(i) / Math.log(2)) + 1;
            
            result = ((result << bitLength) + i) % MOD;
        }
        
        return (int) result;
    }
}
