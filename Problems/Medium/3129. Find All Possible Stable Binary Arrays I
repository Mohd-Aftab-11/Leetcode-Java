class Solution {
    private static final int MOD = 1_000_000_007;
    
    public int numberOfStableArrays(int zero, int one, int limit) {
        int[][][][] dp = new int[zero + 1][one + 1][2][limit + 1];
        
        if (zero > 0) {
            dp[1][0][0][1] = 1;
        }
        if (one > 0) {
            dp[0][1][1][1] = 1;
        }
        
        for (int i = 0; i <= zero; i++) {
            for (int j = 0; j <= one; j++) {
                for (int last = 0; last < 2; last++) {
                    for (int consecutive = 1; consecutive <= limit; consecutive++) {
                        int current = dp[i][j][last][consecutive];
                        if (current == 0) continue;
                        
                        if (last == 0) {
                            if (i + 1 <= zero && consecutive + 1 <= limit) {
                                dp[i + 1][j][0][consecutive + 1] = 
                                    (dp[i + 1][j][0][consecutive + 1] + current) % MOD;
                            }
                            if (j + 1 <= one) {
                                dp[i][j + 1][1][1] = 
                                    (dp[i][j + 1][1][1] + current) % MOD;
                            }
                        } else {
                            if (j + 1 <= one && consecutive + 1 <= limit) {
                                dp[i][j + 1][1][consecutive + 1] = 
                                    (dp[i][j + 1][1][consecutive + 1] + current) % MOD;
                            }
                            if (i + 1 <= zero) {
                                dp[i + 1][j][0][1] = 
                                    (dp[i + 1][j][0][1] + current) % MOD;
                            }
                        }
                    }
                }
            }
        }
        
        long result = 0;
        for (int last = 0; last < 2; last++) {
            for (int consecutive = 1; consecutive <= limit; consecutive++) {
                result = (result + dp[zero][one][last][consecutive]) % MOD;
            }
        }
        
        return (int) result;
    }
}
