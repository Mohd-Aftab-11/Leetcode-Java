class Solution {
    public int minimumPrefixLength(int[] nums) {
        int n = nums.length;
        int suffixStart = n - 1;
        for (int i = n - 2; i >= 0; i--) {
            if (nums[i] < nums[i + 1]) {
                suffixStart = i;
            } else {
                break;
            }
        }
        return suffixStart;
    }
}
