class Solution {
    public String reverseByType(String s) {
        int n = s.length();
        char[] result = new char[n];

        String specialChars = "!@#$%^&*()";

        List<Character> letters = new ArrayList<>();
        List<Character> specials = new ArrayList<>();

        List<Integer> letterIndices = new ArrayList<>();
        List<Integer> specialIndices = new ArrayList<>();

        for(int i = 0; i < n; i++){
            char c = s.charAt(i);
            if (c >= 'a' && c <= 'z'){
                letters.add(c);
                letterIndices.add(i);
            } else if(specialChars.indexOf(c) != -1){
                specials.add(c);
                specialIndices.add(i);
            } else {
                result[i] = c;
            }
        }
        Collections.reverse(letters);
        Collections.reverse(specials);

        for (int i = 0; i < letters.size(); i++) {
            result[letterIndices.get(i)] = letters.get(i);
        }
        for (int i = 0; i < specials.size(); i++) {
            result[specialIndices.get(i)] = specials.get(i);
        }
        return new String(result);
    }
    
}
