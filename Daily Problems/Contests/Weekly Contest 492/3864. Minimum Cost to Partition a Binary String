class Solution {
    public long minCost(String s, int encCost, int flatCost) {
        int n = s.length();
        int[] prefix = new int[n+1];
        for (int i = 0; i < n; i++) {
            prefix[i + 1] = prefix[i] + (s.charAt(i) == '1'?1:0);
        }
        return dfs(0, n-1, prefix, encCost, flatCost);
    }
    private long dfs(int l, int r, int[] pre, int encCost, int flatCost) {
        int len = r - l + 1;
        int ones = pre[r+1] - pre[l];
        long direct;
        if (ones == 0){
            direct = flatCost;
        } else {
            direct = (long) len * ones*encCost;
        }
        if (len % 2 == 0) {
            int mid = (l + r) / 2;
            long left = dfs(l, mid, pre, encCost, flatCost);
            long right = dfs(mid+1, r, pre, encCost, flatCost);
            long split = left + right;
            return Math.min(direct, split);
        } else {
            return direct;
        }
    }
}
