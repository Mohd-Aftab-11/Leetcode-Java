class Solution {
    public int evenSumSubgraphs(int[] nums, int[][] edges) {
        int n = nums.length;
        int m = edges.length;
        int result = 0;

        boolean[][] adj = new boolean[n][n];
        for (int[] edge : edges) {
            int u = edge[0];
            int v = edge[1];
            adj[u][v] = true;
            adj[v][u] = true;
        }

        for (int mask = 1; mask < (1 << n); mask++) {
            int sum = 0;
            for (int i = 0; i < n; i++) {
                if ((mask & (1 << i)) != 0) {
                    sum += nums[i];
                }
            }

            if (sum % 2 == 0 && isConnected(mask, n, adj)) {
                result++;
            }
        }
        return result;
    }
    private boolean isConnected(int mask, int n, boolean[][] adj) {
        int start = -1;
        for (int i = 0; i < n; i++) {
            if ((mask &  (1 << i)) != 0) {
                start = i;
                break;
            }
        }
         if (start == -1) return false;

        boolean[] visited = new boolean[n];
        dfs(start, mask, adj, visited);

        for (int i= 0; i < n; i++) {
            if ((mask & (1 << i)) != 0 && !visited[i]) {
                return false;
            }
        }
        return true;
    }
    private void dfs(int node, int mask, boolean[][] adj, boolean[] visited) {
        visited[node] = true;
        for (int neighbor = 0; neighbor < adj.length; neighbor++) {
            if (!visited[neighbor] && adj[node][neighbor] && (mask & (1 << neighbor)) != 0) {
                dfs(neighbor, mask, adj, visited);
            }
        }
    }
}
