class Solution {
    public String mergeCharacters(String s, int k) {
        StringBuilder sb = new StringBuilder(s);

        boolean merged;

        do {
            merged = false;
            int n = sb.length();

            int leftIndex = -1;
            int rightIndex = -1;

            for (int i = 0; i < n; i++) {
                char currentChar = sb.charAt(i);

                for (int j = i + 1; j < n; j++) {
                    if (sb.charAt(j) == currentChar && (j - i) <= k) {
                        if (leftIndex == -1 || i < leftIndex || ( i == leftIndex && j < rightIndex)) {
                            leftIndex = i;
                            rightIndex = j;
                        }
                        break;
                    }
                }
            }
            if (leftIndex != -1) {
                sb.deleteCharAt(rightIndex);
                merged = true;
            }
        } while (merged);
        return sb.toString();
    }
}
