class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        int[][] temp = new int[k][k];
        
        for (int i = 0; i < k; i++) {
            for (int j = 0; j < k; j++) {
                temp[i][j] = grid[x + i][y + j];
            }
        }
        
        for (int i = 0; i < k / 2; i++) {
            int[] tempRow = temp[i];
            temp[i] = temp[k - 1 - i];
            temp[k - 1 - i] = tempRow;
        }
        
        for (int i = 0; i < k; i++) {
            for (int j = 0; j < k; j++) {
                grid[x + i][y + j] = temp[i][j];
            }
        }
        
        return grid;
    }
}
