class Solution {
    public int maxProductPath(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        int MOD = 1_000_000_007;
        
        long[][] maxProduct = new long[m][n];
        long[][] minProduct = new long[m][n];
        
        maxProduct[0][0] = grid[0][0];
        minProduct[0][0] = grid[0][0];
        
        for (int j = 1; j < n; j++) {
            long val = grid[0][j];
            maxProduct[0][j] = maxProduct[0][j - 1] * val;
            minProduct[0][j] = minProduct[0][j - 1] * val;
        }
        
        for (int i = 1; i < m; i++) {
            long val = grid[i][0];
            maxProduct[i][0] = maxProduct[i - 1][0] * val;
            minProduct[i][0] = minProduct[i - 1][0] * val;
        }
        
        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                long val = grid[i][j];
                
                long fromTopMax = maxProduct[i - 1][j];
                long fromTopMin = minProduct[i - 1][j];
                long fromLeftMax = maxProduct[i][j - 1];
                long fromLeftMin = minProduct[i][j - 1];
                
                if (val >= 0) {
                    maxProduct[i][j] = Math.max(fromTopMax, fromLeftMax) * val;
                    minProduct[i][j] = Math.min(fromTopMin, fromLeftMin) * val;
                } else {
                    maxProduct[i][j] = Math.min(fromTopMin, fromLeftMin) * val;
                    minProduct[i][j] = Math.max(fromTopMax, fromLeftMax) * val;
                }
            }
        }
        
        long result = maxProduct[m - 1][n - 1];
        if (result < 0) {
            return -1;
        }
        return (int)(result % MOD);
    }
}
