class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int n = grid.length;
        int m = grid[0].length;
        int MOD = 12345;
        
        int total = n * m;
        long[] flat = new long[total];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                flat[i * m + j] = grid[i][j] % MOD;
            }
        }
        
        long[] prefix = new long[total];
        prefix[0] = flat[0];
        for (int i = 1; i < total; i++) {
            prefix[i] = (prefix[i - 1] * flat[i]) % MOD;
        }
        
        long[] suffix = new long[total];
        suffix[total - 1] = flat[total - 1];
        for (int i = total - 2; i >= 0; i--) {
            suffix[i] = (suffix[i + 1] * flat[i]) % MOD;
        }
        
        int[][] result = new int[n][m];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                int idx = i * m + j;
                long product = 1;
                
                if (idx > 0) {
                    product = (product * prefix[idx - 1]) % MOD;
                }
                if (idx < total - 1) {
                    product = (product * suffix[idx + 1]) % MOD;
                }
                
                result[i][j] = (int) product;
            }
        }
        return result;
    }
}
