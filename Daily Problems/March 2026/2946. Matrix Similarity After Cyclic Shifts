class Solution {
    public boolean areSimilar(int[][] mat, int k) {
        int m = mat.length;
        int n = mat[0].length;
        
        k = k % n;
        
        if (k == 0) return true;
        
        for (int i = 0; i < m; i++) {
            int[] row = mat[i];
            
            if (i % 2 == 0) {
                for (int j = 0; j < n; j++) {
                    if (row[j] != row[(j + k) % n]) {
                        return false;
                    }
                }
            } 
            else {
                for (int j = 0; j < n; j++) {
                    if (row[j] != row[(j - k + n) % n]) {
                        return false;
                    }
                }
            }
        }
        return true;
    }
}
