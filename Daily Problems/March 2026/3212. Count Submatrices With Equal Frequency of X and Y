class Solution {
    public int numberOfSubmatrices(char[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        
        int[][] prefixX = new int[m + 1][n + 1];
        int[][] prefixY = new int[m + 1][n + 1];
        
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                prefixX[i + 1][j + 1] = prefixX[i][j + 1] + prefixX[i + 1][j] - prefixX[i][j] + (grid[i][j] == 'X' ? 1 : 0); prefixY[i + 1][j + 1] = prefixY[i][j + 1] + prefixY[i + 1][j] - prefixY[i][j] + (grid[i][j] == 'Y' ? 1 : 0);
            }
        }
        
        int count = 0;
        
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                int xCount = prefixX[i + 1][j + 1];
                int yCount = prefixY[i + 1][j + 1];
                
                if (xCount > 0 && xCount == yCount) {
                    count++;
                }
            }
        }
        
        return count;
    }
}
