import java.util.*;

class Solution {
    public int minSteps(int[] arr, int start, int end) {
        if (start == end) return 0;
        
        int MOD = 1000;
        int n = arr.length;
        
        boolean[] visited = new boolean[MOD];
        int[] distance = new int[MOD];
        Queue<Integer> queue = new LinkedList<>();
        
        visited[start] = true;
        distance[start] = 0;
        queue.offer(start);
        
        while (!queue.isEmpty()) {
            int current = queue.poll();
            
            for (int multiplier : arr) {
                int next = (current * multiplier) % MOD;
                
                if (next == end) {
                    return distance[current] + 1;
                }
                if (!visited[next]) {
                    visited[next] = true;
                    distance[next] = distance[current] + 1;
                    queue.offer(next);
                }
            }
        }
        return -1;
    }
}
