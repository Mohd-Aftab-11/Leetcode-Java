class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int n = A.length;
        int[] seenA = new int[n + 1];
        int[] seenB = new int[n + 1];
        int[] C = new int[n];
        int common = 0;
        
        for (int i = 0; i < n; i++) {
            seenA[A[i]]++;
            if (seenA[A[i]] == 1 && seenB[A[i]] == 1) common++;
            
            seenB[B[i]]++;
            if (seenB[B[i]] == 1 && seenA[B[i]] == 1) common++;
            
            C[i] = common;
        }
        return C;
    }
}2
