class Solution {
    public int longestBalanced(String s) {
        int n = s.length();
        int maxLength = 0;
        
        for (int i = 0; i < n; i++) {
            int[] freq = new int[26];
            for (int j = i; j < n; j++) {
                freq[s.charAt(j) - 'a']++;
                
                int minF = Integer.MAX_VALUE;
                int maxF = 0;
                for (int c : freq) {
                    if (c > 0) {
                        minF = Math.min(minF, c);
                        maxF = Math.max(maxF, c);
                    }
                }
                
                if (minF == maxF) {
                    maxLength = Math.max(maxLength, j - i + 1);
                }
            }
        }
        return maxLength;
    }
}
