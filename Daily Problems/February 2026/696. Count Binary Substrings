class Solution {
    public int countBinarySubstrings(String s) {
        if (s == null || s.length() <= 1) {
            return 0;
        }
        
        int result = 0;
        int prevCount = 0;
        int currCount = 1;
        
        for (int i = 1; i < s.length(); i++) {
            if (s.charAt(i) == s.charAt(i - 1)) {
                currCount++;
            } else {
                result += Math.min(prevCount, currCount);
                prevCount = currCount;
                currCount = 1;
            }
        }
        
        result += Math.min(prevCount, currCount);
        
        return result;
    }
}
